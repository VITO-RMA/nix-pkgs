Remove use of std::unary_function from vendored boost container_hash.

std::unary_function (and std::binary_function) were deprecated in C++11,
removed in C++17, and finally removed from libc++ in LLVM 19 (the
_LIBCPP_ENABLE_CXX17_REMOVED_UNARY_BINARY_FUNCTION escape hatch is no
longer available in libc++ 21, shipped with the Apple SDK 26 / Xcode 26
toolchain).

This patches the vendored boost copy inside maplibre-native to always use
the typedef-based hash_base, matching the behavior that newer boost
versions adopted (boost >= 1.81).

diff --git a/vendor/boost/include/boost/container_hash/hash.hpp b/vendor/boost/include/boost/container_hash/hash.hpp
--- a/vendor/boost/include/boost/container_hash/hash.hpp
+++ b/vendor/boost/include/boost/container_hash/hash.hpp
@@ -119,17 +119,12 @@ namespace boost
 {
     namespace hash_detail
     {
-#if defined(_HAS_AUTO_PTR_ETC) && !_HAS_AUTO_PTR_ETC
         template <typename T>
         struct hash_base
         {
             typedef T argument_type;
             typedef std::size_t result_type;
         };
-#else
-        template <typename T>
-        struct hash_base : std::unary_function<T, std::size_t> {};
-#endif
 
         struct enable_hash_value { typedef std::size_t type; };
 
